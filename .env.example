# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# FHIR / SMART mode
# demo: Epic public sandbox defaults are acceptable and sandbox bearer tokens may be held client-side temporarily.
# production: requires institution-approved endpoints, HTTPS APP_URL, server-side token/session storage, audit logging, and no browser token postMessage.
FHIR_INTEGRATION_MODE=demo
VITE_FHIR_INTEGRATION_MODE=demo

# Epic SMART on FHIR Configuration
EPIC_CLIENT_ID=
VITE_EPIC_CLIENT_ID=
# Required only for confidential clients; use a managed secret store in production.
EPIC_CLIENT_SECRET=
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
VITE_EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_AUTH_ENDPOINT=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/authorize
EPIC_TOKEN_ENDPOINT=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token

# Allowed SMART scopes: keep read scopes narrow and add write scopes only after governance approval.
SMART_ALLOWED_SCOPES="openid fhirUser launch patient/Patient.read patient/Encounter.read"
VITE_SMART_ALLOWED_SCOPES="openid fhirUser launch patient/Patient.read patient/Encounter.read"

# Write-back is disabled by default. Enabling requires explicit UI confirmation, attributable actor, audit trail, and approved scope.
FHIR_WRITE_BACK_ENABLED=false
VITE_FHIR_WRITE_BACK_ENABLED=false

# App Configuration
# Required. Production must be HTTPS and match the Epic app redirect URI exactly.
APP_URL=http://localhost:3000
