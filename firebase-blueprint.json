{
  "entities": {
    "Shift": {
      "title": "Shift",
      "description": "Represents a work shift in the ED.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "startTime": { "type": "object", "format": "timestamp" },
        "endTime": { "type": "object", "format": "timestamp" },
        "isActive": { "type": "boolean" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "startTime", "isActive", "createdBy"]
    },
    "Patient": {
      "title": "Patient",
      "description": "A patient currently in the ED for a specific shift.",
      "type": "object",
      "properties": {
        "initials": { "type": "string" },
        "age": { "type": "string" },
        "room": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Staff", "Work-up", "ED Observation", "Likely Discharge", "Likely Admit", "Discharge", "Admit"] },
        "fellowSeen": { "type": "boolean" },
        "attendingSeen": { "type": "boolean" },
        "assignedTeam": { "type": "array", "items": { "type": "string" } },
        "tasks": { "type": "object" },
        "workflowFlags": { "type": "object" },
        "operationalNotes": { "type": "string" },
        "lastAssessmentAt": { "type": "object", "format": "timestamp" },
        "createdAt": { "type": "object", "format": "timestamp" },
        "updatedAt": { "type": "object", "format": "timestamp" }
      },
      "required": ["initials", "age", "room", "status", "fellowSeen", "attendingSeen", "lastAssessmentAt"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "A staff member assigned to a shift.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "initials": { "type": "string" },
        "role": { "type": "string", "enum": ["attending", "fellow", "resident", "student", "nurse", "other"] }
      },
      "required": ["firstName", "lastName", "initials", "role"]
    },
    "MedCommCall": {
      "title": "MedComm Call",
      "description": "An incoming patient call record.",
      "type": "object",
      "properties": {
        "initials": { "type": "string" },
        "age": { "type": "string" },
        "sex": { "type": "string" },
        "callTime": { "type": "object", "format": "timestamp" },
        "status": { "type": "string", "enum": ["pending", "accepted", "arrived", "canceled"] }
      },
      "required": ["initials", "age", "sex", "callTime", "status"]
    }
  },
  "firestore": {
    "/shifts": {
      "schema": "Shift",
      "description": "Root collection for shifts."
    },
    "/shifts/{shiftId}/patients": {
      "schema": "Patient",
      "description": "Patients within a shift."
    },
    "/shifts/{shiftId}/teamMembers": {
      "schema": "TeamMember",
      "description": "Team members assigned to a shift."
    },
    "/shifts/{shiftId}/medCommCalls": {
      "schema": "MedCommCall",
      "description": "Incoming calls for a shift."
    }
  }
}
