rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.email == "nickolas.mancini@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    // Shifts
    match /shifts/{shiftId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isAdmin(); // Only admins can delete shifts
      
      // Patients
      match /patients/{patientId} {
        allow read, create, update, delete: if isAuthenticated();
      }
      
      // Team Members
      match /teamMembers/{memberId} {
        allow read, create, update, delete: if isAuthenticated();
      }
      
      // MedComm Calls
      match /medCommCalls/{callId} {
        allow read, create, update, delete: if isAuthenticated();
      }
    }
    
    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow reading profiles (for team lists)
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
